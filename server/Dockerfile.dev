# Development Dockerfile for Tilt live reload
# Uses air for Go hot-reloading during development
FROM golang:1.26-alpine

WORKDIR /app

# Install air for hot-reloading (using cosmtrek/air which is compatible with Go 1.24)
RUN go install github.com/cosmtrek/air@v1.52.0

# Install git for go modules
RUN apk add --no-cache git

# Copy go mod files first for caching
COPY go.mod go.sum* ./
RUN go mod download

# Copy source code
COPY . .

# Expose port
EXPOSE 8080

# Use air for hot-reloading (watches for file changes and rebuilds)
CMD ["air", "-c", ".air.toml"]
