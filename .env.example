# QA Environment Variables
# Copy this file to .env and fill in your values
# IMPORTANT: Never commit the .env file to version control!

# =============================================================================
# GitHub Configuration
# =============================================================================
# GitHub Personal Access Token for repository connection testing
# Create a token at: https://github.com/settings/tokens
# Required scopes: repo (for private repos) or public_repo (for public repos only)
GITHUB_TOKEN=ghp_your_token_here

# =============================================================================
# JWT Configuration (Optional)
# =============================================================================
# JWT Secret for token signing
# Generate with: openssl rand -base64 32
# If not set, QA deployment will use a test secret (not for production!)
# JWT_SECRET=your-secure-random-string-at-least-32-characters

# =============================================================================
# OIDC Authentication (Optional)
# =============================================================================
# Enable OIDC authentication by setting OIDC_ENABLED=true
# OIDC providers are configured via the knodex-sso-providers ConfigMap and
# knodex-sso-secrets Secret (managed by Helm/ArgoCD or the Settings UI).
# See docs/operator-manual/oidc-integration.md for configuration details.

# OIDC_ENABLED=true

# =============================================================================
# Additional Secrets
# =============================================================================
# Add any additional secrets below as needed
# ANOTHER_SECRET=value_here
