# QA Environment Variables
# Copy this file to .env and fill in your values
# IMPORTANT: Never commit the .env file to version control!

# =============================================================================
# GitHub Configuration
# =============================================================================
# GitHub Personal Access Token for repository connection testing
# Create a token at: https://github.com/settings/tokens
# Required scopes: repo (for private repos) or public_repo (for public repos only)
GITHUB_TOKEN=ghp_your_token_here

# =============================================================================
# PostgreSQL Configuration (Enterprise builds only)
# =============================================================================
# PostgreSQL connection string for audit/compliance persistence.
# OSS builds ignore this. EE builds fail fast if it is empty.
# Local dev (docker-compose): postgres://knodex:knodex@localhost:5432/knodex?sslmode=disable
# Local dev (Tilt + Kind):    postgres://knodex:knodex@knodex-postgres:5432/knodex?sslmode=disable
DATABASE_URL=postgres://knodex:knodex@localhost:5432/knodex?sslmode=disable

# =============================================================================
# Additional Secrets
# =============================================================================
# Add any additional secrets below as needed
# ANOTHER_SECRET=value_here
